<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{pageTitle}} · {{panelTitle}}</title>
  {{#if branding.fontUrl}}
    <link rel="stylesheet" href="{{branding.fontUrl}}" />
  {{/if}}
  <link rel="stylesheet" href="{{basePath}}/assets/admin.css" />
  <link rel="stylesheet" href="{{basePath}}/assets/branding.css" />
  {{#if csrfToken}}
    <meta name="csrf-token" content="{{csrfToken}}" />
  {{/if}}
  <script>
    (function () {
      const stored = localStorage.getItem('loom-theme');
      if (stored === 'dark' || (!stored && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark');
      }
    })();
  </script>
  <script defer src="{{basePath}}/assets/loom-ui.js"></script>
  <script defer src="{{basePath}}/assets/alpine.min.js"></script>
  <style>
    [x-cloak] { display: none !important; }
  </style>
</head>
<body
  class="min-h-screen bg-loom-shell text-body antialiased flex md:flex-row"
  x-data="loomShell()"
  data-loom-base-path="{{basePath}}"
>
  <div
    x-show="sidebarOpen"
    x-cloak
    x-transition.opacity
    class="fixed inset-0 z-20 bg-black/30 md:hidden"
    @click="sidebarOpen = false"
  ></div>

  {{> nav}}

  <div class="flex min-w-0 flex-1 flex-col min-h-screen w-full">
    {{> topbar}}

    <div class="flex-1 flex flex-col min-h-0 overflow-x-hidden w-full p-3 md:p-4 gap-4">
      {{> toast}}

      {{#if pageTitle}}
        {{> page-heading}}
      {{/if}}

      <main class="flex-1 min-h-0 overflow-auto">
        {{{body}}}
      </main>
    </div>
  </div>

  {{> dialog-host}}

  <script>
    function loomShell() {
      return {
        sidebarOpen: false,
        toggleTheme() {
          const root = document.documentElement;
          const next = root.classList.toggle('dark');
          localStorage.setItem('loom-theme', next ? 'dark' : 'light');
        },
      };
    }
  </script>
</body>
</html>
