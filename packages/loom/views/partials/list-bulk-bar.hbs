{{#if bulkEnabled}}
<div
  class="flex flex-wrap items-center justify-between gap-3 border-b border-default px-4 py-3 bg-surface-header"
  x-show="selected.length > 0 || selectAllMatching"
  x-cloak
  @click.outside="bulkOpen = false"
>
  <div class="text-sm text-body space-y-1">
    <p>
      <template x-if="selectAllMatching">
        <span>
          All <span class="font-semibold text-heading" x-text="total"></span> matching records selected
        </span>
      </template>
      <template x-if="!selectAllMatching">
        <span>
          <span class="font-semibold text-heading" x-text="selected.length"></span>
          of
          <span class="font-semibold text-heading" x-text="total"></span>
          selected
        </span>
      </template>
    </p>
    <p x-show="!selectAllMatching && pageFullySelected && total > selected.length" x-cloak>
      <button
        type="button"
        class="text-fg-brand hover:underline font-medium"
        @click="selectAllInResultSet()"
      >
        Select all <span x-text="total"></span> matching records
      </button>
    </p>
    <p x-show="selectAllMatching" x-cloak>
      <button type="button" class="text-body-subtle hover:underline" @click="clearSelection()">
        Clear selection
      </button>
    </p>
  </div>
  <div class="flex flex-wrap items-center gap-2">
    {{#if (gt bulkActions.length 2)}}
      <div class="relative">
        <button
          type="button"
          class="inline-flex items-center gap-1.5 px-3 py-1.5 text-sm font-medium rounded-md border border-default text-body hover:bg-surface-hover"
          @click="bulkOpen = !bulkOpen"
          :aria-expanded="bulkOpen.toString()"
        >
          Actions
          <svg class="w-3.5 h-3.5 text-body-subtle" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5"/>
          </svg>
        </button>
        <div
          x-show="bulkOpen"
          x-cloak
          x-transition
          class="absolute right-0 top-full z-40 mt-1 min-w-[12rem] loom-card rounded-xl shadow-lg py-1"
        >
          {{#each bulkActions}}
            {{#if (eq method 'POST')}}
              <button
                type="button"
                class="w-full text-left px-3 py-2 text-sm {{#if (eq color 'danger')}}text-fg-danger hover:bg-danger-soft{{else}}text-body hover:bg-surface-hover{{/if}}"
                @click="bulkOpen = false; submitBulk('{{url}}', '{{name}}', {{#if confirm}}'{{confirm}}'{{else}}null{{/if}})"
              >{{label}}</button>
            {{else}}
              <a href="{{url}}" class="block px-3 py-2 text-sm text-body hover:bg-surface-hover">{{label}}</a>
            {{/if}}
          {{/each}}
        </div>
      </div>
    {{else}}
      {{#each bulkActions}}
        {{#if (eq method 'POST')}}
          <button
            type="button"
            class="inline-flex items-center gap-1.5 px-3 py-1.5 text-sm font-medium rounded-md {{#if (eq color 'danger')}}text-fg-danger hover:bg-danger-soft border border-transparent{{else}}text-body hover:bg-surface-hover border border-default{{/if}}"
            @click="submitBulk('{{url}}', '{{name}}', {{#if confirm}}'{{confirm}}'{{else}}null{{/if}})"
          >{{label}}</button>
        {{else}}
          <a href="{{url}}" class="inline-flex items-center gap-1.5 px-3 py-1.5 text-sm font-medium text-body rounded-md border border-default hover:bg-surface-hover">{{label}}</a>
        {{/if}}
      {{/each}}
    {{/if}}
  </div>
</div>
{{/if}}
