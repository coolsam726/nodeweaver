<div
  x-data="loomDialogHost()"
  @loom-open-dialog.window="openModal($event.detail)"
  @loom-open-confirm.window="openConfirm($event.detail)"
  @keydown.escape.window="if (open) close()"
>
  <template x-if="open">
    <div>
      <div class="loom-dialog-backdrop" @click="close()"></div>

      <div
        class="loom-dialog-panel"
        role="dialog"
        aria-modal="true"
        :aria-label="title"
        :class="{ 'is-fullscreen': fullscreen }"
        :style="panelStyle()"
        @click.stop
        @keydown.tab="trapFocus($event)"
        x-ref="panel"
      >
        <div class="loom-dialog-header" @mousedown="startDrag($event)">
          <h2 class="min-w-0 flex-1 truncate text-sm font-semibold text-heading" id="loom-dialog-title" x-text="title"></h2>
          <div class="flex shrink-0 items-center gap-1">
            <template x-if="fullPageUrl">
              <a
                :href="fullPageUrl"
                class="rounded-md px-2 py-1 text-xs text-body-subtle hover:bg-surface-hover hover:text-heading"
              >Open in full page</a>
            </template>
            <button
              type="button"
              class="rounded-md p-1.5 text-body-subtle hover:bg-surface-hover hover:text-heading"
              @click="toggleFullscreen()"
              :title="fullscreen ? 'Exit full screen' : 'Full screen'"
            >
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3.75v4.5m0-4.5h4.5m-4.5 0L9 9M3.75 20.25v-4.5m0 4.5h4.5m-4.5 0L9 15M20.25 3.75h-4.5m4.5 0v4.5m0-4.5L15 9m5.25 11.25h-4.5m4.5 0v-4.5m0 4.5L15 15"/>
              </svg>
            </button>
            <button
              type="button"
              class="rounded-md p-1.5 text-body-subtle hover:bg-surface-hover hover:text-heading"
              @click="close()"
              title="Close"
              aria-label="Close"
              x-ref="closeBtn"
            >×</button>
          </div>
        </div>

        <div class="loom-dialog-body relative">
          <div x-show="loading" class="py-8 text-center text-sm text-body-subtle">Loading…</div>
          <div x-show="confirmMode && !loading" class="text-sm text-body-subtle" x-text="confirmMessage"></div>
          <div x-show="!confirmMode && !loading" x-ref="body"></div>
        </div>

        <template x-if="confirmMode">
          <div class="loom-dialog-footer">
            <button type="button" class="rounded-md px-4 py-2 text-sm hover:bg-surface-hover" @click="close()">Cancel</button>
            <button type="button" class="rounded-md bg-fg-danger px-4 py-2 text-sm font-medium text-white hover:opacity-90" @click="submitConfirm()">Delete</button>
          </div>
        </template>

        <template x-if="!confirmMode && !fullscreen">
          <div class="loom-dialog-resize-handle" @mousedown="startResize($event)"></div>
        </template>
      </div>
    </div>
  </template>
</div>
