<div>
  <label for="field-{{name}}" class="mb-2 block text-sm font-medium text-heading">
    {{label}}{{#if required}} <span class="text-fg-brand">*</span>{{/if}}
  </label>

  {{#if (eq type 'textarea')}}
    <textarea id="field-{{name}}" name="{{name}}" rows="4" {{#if required}}required{{/if}} placeholder="{{placeholder}}" class="velm-input">{{lookup @root.record name}}</textarea>
  {{else if (eq type 'boolean')}}
    <label class="inline-flex items-center gap-2 text-sm">
      <input id="field-{{name}}" type="checkbox" name="{{name}}" value="true" class="rounded border-default text-fg-brand focus:ring-fg-brand" {{#if (lookup @root.record name)}}checked{{/if}} />
      Enabled
    </label>
  {{else if (eq type 'select')}}
    <select id="field-{{name}}" name="{{name}}" {{#if required}}required{{/if}} class="velm-select">
      <option value="">Select...</option>
      {{#each options}}
        <option value="{{value}}" {{#if (eq value (lookup @root.record ../name))}}selected{{/if}}>{{label}}</option>
      {{/each}}
    </select>
  {{else if (eq type 'password')}}
    <input id="field-{{name}}" type="password" name="{{name}}" {{#if required}}required{{/if}} class="velm-input" autocomplete="new-password" />
  {{else}}
    <input
      id="field-{{name}}"
      type="{{formInputType this}}"
      name="{{name}}"
      value="{{lookup @root.record name}}"
      {{#if required}}required{{/if}}
      {{#if maxLength}}maxlength="{{maxLength}}"{{/if}}
      placeholder="{{placeholder}}"
      class="velm-input"
    />
  {{/if}}

  {{#if help}}<p class="mt-2 text-xs text-velm-muted">{{help}}</p>{{/if}}
</div>
