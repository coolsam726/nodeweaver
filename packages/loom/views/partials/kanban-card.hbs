{{#if (eq resource.presentation.detail 'modal')}}
  <button
    type="button"
    class="loom-card rounded-xl block w-full p-4 text-left transition hover:bg-surface-row-hover"
    @click="$dispatch('loom-open-dialog', { url: '{{basePath}}/{{resource.slug}}/{{id}}', title: '{{kanbanCardTitle this kanban}}', slug: '{{resource.slug}}' })"
  >
    <h4 class="font-medium text-heading">{{kanbanCardTitle this kanban}}</h4>
    {{#if kanban.card.subtitleField}}
      <p class="mt-1 text-xs text-body-subtle">{{lookup this kanban.card.subtitleField}}</p>
    {{/if}}
    {{#if kanban.card.fields}}
      <dl class="mt-3 space-y-1">
        {{#each kanban.card.fields}}
          <div class="flex justify-between gap-2 text-xs">
            <dt class="text-body-subtle capitalize">{{this}}</dt>
            <dd class="font-medium text-body">{{kanbanFieldValue .. this}}</dd>
          </div>
        {{/each}}
      </dl>
    {{/if}}
  </button>
{{else}}
  <a
    href="{{basePath}}/{{resource.slug}}/{{id}}"
    class="loom-card rounded-xl block p-4 transition hover:bg-surface-row-hover"
  >
    <h4 class="font-medium text-heading">{{kanbanCardTitle this kanban}}</h4>
    {{#if kanban.card.subtitleField}}
      <p class="mt-1 text-xs text-body-subtle">{{lookup this kanban.card.subtitleField}}</p>
    {{/if}}
    {{#if kanban.card.fields}}
      <dl class="mt-3 space-y-1">
        {{#each kanban.card.fields}}
          <div class="flex justify-between gap-2 text-xs">
            <dt class="text-body-subtle capitalize">{{this}}</dt>
            <dd class="font-medium text-body">{{kanbanFieldValue .. this}}</dd>
          </div>
        {{/each}}
      </dl>
    {{/if}}
  </a>
{{/if}}
