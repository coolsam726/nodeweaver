<form method="get" class="flex flex-col gap-3 px-4 py-3 sm:flex-row sm:items-center sm:justify-between">
  <div class="relative min-w-0 flex-1 sm:max-w-md">
    <svg class="pointer-events-none absolute left-3 top-1/2 h-4 w-4 -translate-y-1/2 text-body-subtle" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 15.803 7.5 7.5 0 0015.803 15.803z"/>
    </svg>
    <input
      type="search"
      name="search"
      value="{{query.search}}"
      placeholder="Search records…"
      class="loom-input pl-9"
    />
    {{#if query.sort}}
      <input type="hidden" name="sort" value="{{query.sort}}" />
      <input type="hidden" name="direction" value="{{query.direction}}" />
    {{/if}}
  </div>

  <div class="flex items-center gap-2 shrink-0">
    {{#if softDeleteEnabled}}
      {{#if trashed}}
        <a href="{{basePath}}/{{resource.slug}}" class="text-xs font-medium text-fg-brand hover:underline whitespace-nowrap">Active</a>
      {{else}}
        <a href="{{basePath}}/{{resource.slug}}?trashed=1" class="text-xs font-medium text-body-subtle hover:text-heading whitespace-nowrap">Trash</a>
      {{/if}}
    {{/if}}
    <label for="list-per-page" class="text-xs font-medium text-body-subtle whitespace-nowrap">Rows per page</label>
    <select
      id="list-per-page"
      name="perPage"
      onchange="this.form.submit()"
      class="loom-select w-auto min-w-[4.5rem]"
    >
      <option value="10" {{#if (eq query.perPage 10)}}selected{{/if}}>10</option>
      <option value="15" {{#if (eq query.perPage 15)}}selected{{/if}}>15</option>
      <option value="20" {{#if (eq query.perPage 20)}}selected{{/if}}>20</option>
      <option value="50" {{#if (eq query.perPage 50)}}selected{{/if}}>50</option>
    </select>
    <button
      type="button"
      class="loom-list-refresh"
      data-loom-list-refresh
      title="Refresh (double-click for auto-refresh every 10s)"
      aria-label="Refresh list"
    >
      <svg class="loom-list-refresh__icon h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182"/>
      </svg>
    </button>
  </div>
</form>
