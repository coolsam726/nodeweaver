<section
  class="space-y-4"
  data-velm-list-root="{{resource.slug}}"
  data-velm-base-path="{{basePath}}"
  data-velm-current-view="table"
  data-velm-has-kanban="{{#if resource.hasKanban}}true{{else}}false{{/if}}"
>
  <div class="velm-card rounded-xl overflow-hidden">
    <form method="get" class="flex flex-col gap-3 px-4 py-3 sm:flex-row sm:items-center sm:justify-between">
      <div class="relative min-w-0 flex-1 sm:max-w-md">
        <svg class="pointer-events-none absolute left-3 top-1/2 h-4 w-4 -translate-y-1/2 text-body-subtle" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 15.803 7.5 7.5 0 0015.803 15.803z"/>
        </svg>
        <input
          type="search"
          name="search"
          value="{{query.search}}"
          placeholder="Search records…"
          class="velm-input pl-9"
        />
        {{#if query.sort}}
          <input type="hidden" name="sort" value="{{query.sort}}" />
          <input type="hidden" name="direction" value="{{query.direction}}" />
        {{/if}}
      </div>

      <div class="flex items-center gap-2 shrink-0">
        <label for="list-per-page" class="text-xs font-medium text-body-subtle whitespace-nowrap">Rows per page</label>
        <select
          id="list-per-page"
          name="perPage"
          onchange="this.form.submit()"
          class="velm-select w-auto min-w-[4.5rem]"
        >
          <option value="10" {{#if (eq query.perPage 10)}}selected{{/if}}>10</option>
          <option value="15" {{#if (eq query.perPage 15)}}selected{{/if}}>15</option>
          <option value="20" {{#if (eq query.perPage 20)}}selected{{/if}}>20</option>
          <option value="50" {{#if (eq query.perPage 50)}}selected{{/if}}>50</option>
        </select>
      </div>
    </form>

    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead class="bg-surface-header">
          <tr>
            <th class="w-9 px-3 py-3" aria-label="Select">
              <span class="block w-3.5 h-3.5 rounded bg-surface-inset"></span>
            </th>
            {{#each resource.columns}}
              <th class="text-left px-4 py-3 text-xs font-semibold uppercase tracking-wider text-body-subtle whitespace-nowrap">
                {{#if sortable}}
                  <a
                    href="{{sortColumnUrl ../../basePath ../../resource.slug ../../query name}}"
                    class="inline-flex items-center gap-1 hover:text-heading transition-colors"
                  >
                    {{label}}
                    {{#if (eq ../../query.sort name)}}
                      <svg class="w-3 h-3 text-fg-brand {{#if (eq ../../query.direction 'desc')}}rotate-180{{/if}}" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 15.75l7.5-7.5 7.5 7.5"/>
                      </svg>
                    {{/if}}
                  </a>
                {{else}}
                  {{label}}
                {{/if}}
              </th>
            {{/each}}
            <th class="px-4 py-3 text-right text-xs font-semibold uppercase tracking-wider text-body-subtle">Actions</th>
          </tr>
        </thead>
        <tbody>
          {{#each result.items}}
            <tr class="hover:bg-surface-row-hover transition-colors">
              <td class="px-3 py-3"></td>
              {{#each ../resource.columns}}
                <td class="px-4 py-3 text-body">
                  {{#if (eq type 'boolean')}}
                    <span class="inline-flex rounded-full px-2 py-0.5 text-xs font-medium {{#if (lookup ../this name)}}bg-success-soft text-success-strong{{else}}bg-badge-neutral text-body-subtle{{/if}}">
                      {{cellValue .. this}}
                    </span>
                  {{else}}
                    {{#if (eq ../../resource.presentation.detail 'modal')}}
                      <button
                        type="button"
                        class="text-heading hover:text-fg-brand hover:underline text-left"
                        @click="$dispatch('velm-open-dialog', { url: '{{../../basePath}}/{{../../resource.slug}}/{{../this.id}}', title: 'View record', slug: '{{../../resource.slug}}' })"
                      >{{cellValue .. this}}</button>
                    {{else}}
                      <a href="{{../../basePath}}/{{../../resource.slug}}/{{../this.id}}" class="text-heading hover:text-fg-brand hover:underline">{{cellValue .. this}}</a>
                    {{/if}}
                  {{/if}}
                </td>
              {{/each}}
              <td class="px-4 py-3 text-right">
                <div class="inline-flex items-center gap-1 text-xs">
                  {{#if (eq ../resource.presentation.detail 'modal')}}
                    <button type="button" class="px-2 py-1 rounded-md text-fg-brand hover:bg-surface-hover" @click="$dispatch('velm-open-dialog', { url: '{{../basePath}}/{{../resource.slug}}/{{this.id}}', title: 'View record', slug: '{{../resource.slug}}' })">View</button>
                  {{else}}
                    <a href="{{../basePath}}/{{../resource.slug}}/{{this.id}}" class="px-2 py-1 rounded-md text-fg-brand hover:bg-surface-hover">View</a>
                  {{/if}}
                  {{#if (eq ../resource.presentation.form 'modal')}}
                    <button type="button" class="px-2 py-1 rounded-md text-body hover:bg-surface-hover" @click="$dispatch('velm-open-dialog', { url: '{{../basePath}}/{{../resource.slug}}/{{this.id}}/edit', title: 'Edit record', slug: '{{../resource.slug}}' })">Edit</button>
                  {{else}}
                    <a href="{{../basePath}}/{{../resource.slug}}/{{this.id}}/edit" class="px-2 py-1 rounded-md text-body hover:bg-surface-hover">Edit</a>
                  {{/if}}
                  <button
                    type="button"
                    class="px-2 py-1 rounded-md text-fg-danger hover:bg-danger-soft"
                    @click="$dispatch('velm-open-confirm', { title: 'Delete record?', message: 'This action cannot be undone.', action: '{{../basePath}}/{{../resource.slug}}/{{this.id}}/delete' })"
                  >Delete</button>
                </div>
              </td>
            </tr>
          {{else}}
            <tr>
              <td colspan="100" class="px-4 py-12 text-center text-body-subtle">No records found.</td>
            </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
  </div>

  {{> pagination}}
</section>
