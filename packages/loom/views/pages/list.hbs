<section
  class="space-y-4"
  data-loom-list-root="{{resource.slug}}"
  data-loom-base-path="{{basePath}}"
  data-loom-current-view="table"
  data-loom-has-kanban="{{#if resource.hasKanban}}true{{else}}false{{/if}}"
>
  <div class="loom-card rounded-xl overflow-hidden">
    {{> list-toolbar}}

    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead class="bg-surface-header">
          <tr>
            <th class="w-9 px-3 py-3" aria-label="Select">
              <span class="block w-3.5 h-3.5 rounded bg-surface-inset"></span>
            </th>
            {{#each resource.columns}}
              <th class="text-left px-4 py-3 text-xs font-semibold uppercase tracking-wider text-body-subtle whitespace-nowrap">
                {{#if sortable}}
                  <a
                    href="{{sortColumnUrl ../../basePath ../../resource.slug ../../query name}}"
                    class="inline-flex items-center gap-1 hover:text-heading transition-colors"
                  >
                    {{label}}
                    {{#if (eq ../../query.sort name)}}
                      <svg class="w-3 h-3 text-fg-brand {{#if (eq ../../query.direction 'desc')}}rotate-180{{/if}}" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 15.75l7.5-7.5 7.5 7.5"/>
                      </svg>
                    {{/if}}
                  </a>
                {{else}}
                  {{label}}
                {{/if}}
              </th>
            {{/each}}
            {{#if (or (not @root.abilities) @root.abilities.canView @root.abilities.canEdit @root.abilities.canDelete)}}
              <th class="px-4 py-3 text-right text-xs font-semibold uppercase tracking-wider text-body-subtle">Actions</th>
            {{/if}}
          </tr>
        </thead>
        <tbody>
          {{#each result.items}}
            <tr class="hover:bg-surface-row-hover transition-colors">
              <td class="px-3 py-3"></td>
              {{#each ../resource.columns}}
                <td class="px-4 py-3 text-body">
                  {{#if (eq type 'boolean')}}
                    <span class="inline-flex rounded-full px-2 py-0.5 text-xs font-medium {{#if (lookup ../this name)}}bg-success-soft text-success-strong{{else}}bg-badge-neutral text-body-subtle{{/if}}">
                      {{cellValue .. this}}
                    </span>
                  {{else}}
                    {{#if (eq ../../resource.presentation.detail 'modal')}}
                      <button
                        type="button"
                        class="text-heading hover:text-fg-brand hover:underline text-left"
                        {{#if (or (not @root.abilities) @root.abilities.canView)}}
                          @click="$dispatch('loom-open-dialog', { url: '{{../../basePath}}/{{../../resource.slug}}/{{../this.id}}', title: 'View record', slug: '{{../../resource.slug}}' })"
                        {{else}}
                          disabled
                        {{/if}}
                      >{{cellValue .. this}}</button>
                    {{else}}
                      {{#if (or (not @root.abilities) @root.abilities.canView)}}
                        <a href="{{../../basePath}}/{{../../resource.slug}}/{{../this.id}}" class="text-heading hover:text-fg-brand hover:underline">{{cellValue .. this}}</a>
                      {{else}}
                        <span class="text-heading">{{cellValue .. this}}</span>
                      {{/if}}
                    {{/if}}
                  {{/if}}
                </td>
              {{/each}}
              {{#if (or (not @root.abilities) @root.abilities.canView @root.abilities.canEdit @root.abilities.canDelete)}}
              <td class="px-4 py-3 text-right">
                <div class="inline-flex items-center gap-1 text-xs">
                  {{#if (or (not @root.abilities) @root.abilities.canView)}}
                    {{#if (eq ../resource.presentation.detail 'modal')}}
                      <button type="button" class="px-2 py-1 rounded-md text-fg-brand hover:bg-surface-hover" @click="$dispatch('loom-open-dialog', { url: '{{../basePath}}/{{../resource.slug}}/{{this.id}}', title: 'View record', slug: '{{../resource.slug}}' })">View</button>
                    {{else}}
                      <a href="{{../basePath}}/{{../resource.slug}}/{{this.id}}" class="px-2 py-1 rounded-md text-fg-brand hover:bg-surface-hover">View</a>
                    {{/if}}
                  {{/if}}
                  {{#if (or (not @root.abilities) @root.abilities.canEdit)}}
                    {{#if (eq ../resource.presentation.form 'modal')}}
                      <button type="button" class="px-2 py-1 rounded-md text-body hover:bg-surface-hover" @click="$dispatch('loom-open-dialog', { url: '{{../basePath}}/{{../resource.slug}}/{{this.id}}/edit', title: 'Edit record', slug: '{{../resource.slug}}' })">Edit</button>
                    {{else}}
                      <a href="{{../basePath}}/{{../resource.slug}}/{{this.id}}/edit" class="px-2 py-1 rounded-md text-body hover:bg-surface-hover">Edit</a>
                    {{/if}}
                  {{/if}}
                  {{#if @root.trashed}}
                    {{#if (or (not @root.abilities) @root.abilities.canEdit)}}
                      <form method="post" action="{{../basePath}}/{{../resource.slug}}/{{this.id}}/restore" class="inline">
                        {{> csrf}}
                        <button type="submit" class="px-2 py-1 rounded-md text-fg-brand hover:bg-surface-hover">Restore</button>
                      </form>
                    {{/if}}
                  {{else}}
                  {{#if (or (not @root.abilities) @root.abilities.canDelete)}}
                    <button
                      type="button"
                      class="px-2 py-1 rounded-md text-fg-danger hover:bg-danger-soft"
                      @click="$dispatch('loom-open-confirm', { title: 'Delete record?', message: 'This action cannot be undone.', action: '{{../basePath}}/{{../resource.slug}}/{{this.id}}/delete' })"
                    >Delete</button>
                  {{/if}}
                  {{/if}}
                </div>
              </td>
              {{/if}}
            </tr>
          {{else}}
            <tr>
              <td colspan="100" class="px-4 py-12 text-center text-body-subtle">No records found.</td>
            </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
  </div>

  {{> pagination}}
</section>
