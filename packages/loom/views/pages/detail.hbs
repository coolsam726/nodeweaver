{{#if embed}}
  {{#each resource.infolist.sections}}
    <section class="loom-embed-section">
      <div class="loom-embed-section__header">
        <h3 class="text-sm font-semibold text-heading">{{title}}</h3>
        {{#if description}}<p class="mt-1 text-sm text-body-subtle">{{description}}</p>{{/if}}
      </div>
      <dl class="loom-detail-grid" style="--loom-detail-cols: {{#if columns}}{{columns}}{{else}}2{{/if}}">
        {{#each entries}}
          <div class="loom-detail-cell" style="{{gridItemStyle this (or ../columns 2)}}">
            <dt class="loom-field__label">{{label}}</dt>
            <dd class="loom-field__value mt-1">
              {{#if (eq type 'image')}}
                {{#if (lookup ../../record name)}}
                  <img
                    src="{{lookup ../../record name}}"
                    alt="{{label}}"
                    class="max-h-32 rounded-md border border-default object-contain"
                  />
                {{else}}
                  —
                {{/if}}
              {{else if (eq format 'boolean')}}
                <span class="loom-boolean-badge {{#if (lookup ../../record name)}}is-true{{else}}is-false{{/if}}">
                  {{entryValue ../../record this}}
                </span>
              {{else}}
                {{entryValue ../../record this}}
              {{/if}}
            </dd>
          </div>
        {{/each}}
      </dl>
    </section>
  {{/each}}
  <div data-loom-dialog-actions>
    <button
      type="button"
      data-loom-dialog-close
      class="inline-flex items-center gap-1.5 px-3 py-1.5 text-sm font-medium border border-default text-body rounded-md hover:bg-surface-hover transition"
    >Close</button>
    {{#if (or (not abilities) abilities.canEdit)}}
    <button
      type="button"
      class="inline-flex items-center gap-1.5 px-3 py-1.5 text-sm font-medium text-white rounded-md bg-fg-brand hover:opacity-90 transition"
      @click="window.LoomUI.openDialog({ url: '{{basePath}}/{{resource.slug}}/{{id}}/edit', title: 'Edit {{resource.singularLabel}}', slug: '{{resource.slug}}', replace: true })"
    >Edit</button>
    {{/if}}
  </div>
{{else}}
<div class="mx-auto max-w-5xl space-y-6">
  {{#each resource.infolist.sections}}
    <div class="loom-card rounded-xl overflow-hidden">
      <div class="px-6 py-4 bg-surface-header">
        <h2 class="font-semibold text-heading">{{title}}</h2>
        {{#if description}}<p class="mt-1 text-sm text-body-subtle">{{description}}</p>{{/if}}
      </div>
      <dl class="loom-detail-grid" style="--loom-detail-cols: {{#if columns}}{{columns}}{{else}}2{{/if}}">
        {{#each entries}}
          <div class="loom-detail-cell px-6 py-4 border-t border-card-border sm:border-t-0 sm:border-r sm:border-card-border last:border-r-0" style="{{gridItemStyle this (or ../columns 2)}}">
            <dt class="loom-field__label">{{label}}</dt>
            <dd class="loom-field__value mt-1">
              {{#if (eq type 'image')}}
                {{#if (lookup ../../record name)}}
                  <img
                    src="{{lookup ../../record name}}"
                    alt="{{label}}"
                    class="max-h-32 rounded-md border border-default object-contain"
                  />
                {{else}}
                  —
                {{/if}}
              {{else if (eq format 'boolean')}}
                <span class="loom-boolean-badge {{#if (lookup ../../record name)}}is-true{{else}}is-false{{/if}}">
                  {{entryValue ../../record this}}
                </span>
              {{else}}
                {{entryValue ../../record this}}
              {{/if}}
            </dd>
          </div>
        {{/each}}
      </dl>
    </div>
  {{/each}}
</div>
{{/if}}
