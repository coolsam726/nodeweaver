{{#if embed}}
  {{#each resource.infolist.sections}}
    <div class="velm-card rounded-xl overflow-hidden mb-4 last:mb-0">
      <div class="px-4 py-3 bg-surface-header">
        <h2 class="font-semibold text-heading text-sm">{{title}}</h2>
        {{#if description}}<p class="mt-1 text-sm text-body-subtle">{{description}}</p>{{/if}}
      </div>
      <dl class="grid gap-0 sm:grid-cols-{{columns}}">
        {{#each entries}}
          <div class="px-4 py-3 sm:border-r sm:border-default/40 last:border-r-0">
            <dt class="text-xs font-semibold uppercase tracking-wide text-body-subtle">{{label}}</dt>
            <dd class="mt-1 text-sm text-body">
              {{#if (eq format 'boolean')}}
                <span class="inline-flex rounded-full px-2.5 py-0.5 text-xs font-medium {{#if (lookup ../../record name)}}bg-success-soft text-success-strong{{else}}bg-badge-neutral text-body-subtle{{/if}}">
                  {{entryValue ../../record this}}
                </span>
              {{else}}
                {{entryValue ../../record this}}
              {{/if}}
            </dd>
          </div>
        {{/each}}
      </dl>
    </div>
  {{/each}}
  <div class="flex justify-end gap-2 pt-1">
    <a href="{{basePath}}/{{resource.slug}}/{{id}}/edit" class="inline-flex items-center gap-1.5 px-3 py-1.5 text-sm font-medium text-white rounded-md bg-fg-brand hover:opacity-90 transition">Edit</a>
  </div>
{{else}}
<div class="mx-auto max-w-5xl space-y-6">
  {{#each resource.infolist.sections}}
    <div class="velm-card rounded-xl overflow-hidden">
      <div class="px-6 py-4 bg-surface-header">
        <h2 class="font-semibold text-heading">{{title}}</h2>
        {{#if description}}<p class="mt-1 text-sm text-body-subtle">{{description}}</p>{{/if}}
      </div>
      <dl class="grid gap-0 sm:grid-cols-{{columns}}">
        {{#each entries}}
          <div class="px-6 py-4 sm:border-r sm:border-default/40 last:border-r-0">
            <dt class="text-xs font-semibold uppercase tracking-wide text-body-subtle">{{label}}</dt>
            <dd class="mt-1 text-sm text-body">
              {{#if (eq format 'boolean')}}
                <span class="inline-flex rounded-full px-2.5 py-0.5 text-xs font-medium {{#if (lookup ../../record name)}}bg-success-soft text-success-strong{{else}}bg-badge-neutral text-body-subtle{{/if}}">
                  {{entryValue ../../record this}}
                </span>
              {{else}}
                {{entryValue ../../record this}}
              {{/if}}
            </dd>
          </div>
        {{/each}}
      </dl>
    </div>
  {{/each}}
</div>
{{/if}}
