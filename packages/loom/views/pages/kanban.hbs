<section
  class="space-y-4"
  data-loom-list-root="{{resource.slug}}"
  data-loom-base-path="{{basePath}}"
  data-loom-current-view="kanban"
  data-loom-has-kanban="{{#if resource.hasKanban}}true{{else}}false{{/if}}"
>
  <div class="loom-card rounded-xl overflow-hidden">
    {{> list-toolbar}}
  </div>

  {{#if kanban.groupBy}}
    <div class="loom-kanban-board" role="list">
      {{#each columns}}
        <section class="loom-kanban-column" role="listitem" data-kanban-column="{{key}}">
          <header class="loom-kanban-column__header">
            <h3 class="loom-kanban-column__title">{{label}}</h3>
            <span class="loom-kanban-column__count">{{items.length}}</span>
          </header>
          <div class="loom-kanban-column__body">
            {{#if items.length}}
              {{#each items}}
                {{> kanban-card basePath=../../basePath resource=../../resource kanban=../../kanban}}
              {{/each}}
            {{else}}
              <p class="loom-kanban-column__empty">No cards</p>
            {{/if}}
          </div>
        </section>
      {{/each}}
    </div>
  {{else}}
    {{#each columns}}
      {{#if @first}}
        {{#if items.length}}
          <div
            class="loom-kanban-grid"
            style="--loom-kanban-cols: {{#if ../kanban.gridColumns}}{{../kanban.gridColumns}}{{else}}4{{/if}}"
          >
            {{#each items}}
              {{> kanban-card basePath=../../basePath resource=../../resource kanban=../../kanban}}
            {{/each}}
          </div>
        {{else}}
          <p class="px-2 py-12 text-center text-sm text-body-subtle loom-card rounded-xl">No cards</p>
        {{/if}}
      {{/if}}
    {{/each}}
  {{/if}}

  {{> pagination}}
</section>
