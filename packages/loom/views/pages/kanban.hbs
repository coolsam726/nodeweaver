<section
  class="space-y-4"
  data-velm-list-root="{{resource.slug}}"
  data-velm-base-path="{{basePath}}"
  data-velm-current-view="kanban"
  data-velm-has-kanban="{{#if resource.hasKanban}}true{{else}}false{{/if}}"
>
  <div class="velm-card rounded-xl overflow-hidden">
    <form method="get" class="px-4 py-3">
      <div class="relative min-w-0 sm:max-w-md">
        <svg class="pointer-events-none absolute left-3 top-1/2 h-4 w-4 -translate-y-1/2 text-body-subtle" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 15.803 7.5 7.5 0 0015.803 15.803z"/>
        </svg>
        <input type="search" name="search" value="{{query.search}}" placeholder="Search records…" class="velm-input pl-9" />
        <button type="submit" class="sr-only">Search</button>
      </div>
    </form>
  </div>

  {{#if kanban.groupBy}}
    <div class="space-y-8">
      {{#each columns}}
        <section class="space-y-3">
          <div class="flex items-baseline justify-between gap-2 px-0.5">
            <h3 class="text-sm font-semibold text-heading">{{label}}</h3>
            <span class="text-xs text-body-subtle">{{items.length}} records</span>
          </div>
          {{#if items.length}}
            <div
              class="velm-kanban-grid"
              style="--velm-kanban-cols: {{#if ../kanban.gridColumns}}{{../kanban.gridColumns}}{{else}}4{{/if}}"
            >
              {{#each items}}
                {{> kanban-card basePath=../../basePath resource=../../resource kanban=../../kanban}}
              {{/each}}
            </div>
          {{else}}
            <p class="px-2 py-8 text-center text-sm text-body-subtle velm-card rounded-xl">No cards</p>
          {{/if}}
        </section>
      {{/each}}
    </div>
  {{else}}
    {{#each columns}}
      {{#if @first}}
        {{#if items.length}}
          <div
            class="velm-kanban-grid"
            style="--velm-kanban-cols: {{#if ../kanban.gridColumns}}{{../kanban.gridColumns}}{{else}}4{{/if}}"
          >
            {{#each items}}
              {{> kanban-card basePath=../../basePath resource=../../resource kanban=../../kanban}}
            {{/each}}
          </div>
        {{else}}
          <p class="px-2 py-12 text-center text-sm text-body-subtle velm-card rounded-xl">No cards</p>
        {{/if}}
      {{/if}}
    {{/each}}
  {{/if}}
</section>
