<section
  class="space-y-4"
  data-loom-list-root="{{resource.slug}}"
  data-loom-base-path="{{basePath}}"
  data-loom-current-view="kanban"
  data-loom-has-kanban="{{#if resource.hasKanban}}true{{else}}false{{/if}}"
>
  <div class="loom-card rounded-xl overflow-hidden">
    {{> list-toolbar}}
  </div>

  {{#if kanban.groupBy}}
    <div class="space-y-8">
      {{#each columns}}
        <section class="space-y-3">
          <div class="flex items-baseline justify-between gap-2 px-0.5">
            <h3 class="text-sm font-semibold text-heading">{{label}}</h3>
            <span class="text-xs text-body-subtle">{{items.length}} records</span>
          </div>
          {{#if items.length}}
            <div
              class="loom-kanban-grid"
              style="--loom-kanban-cols: {{#if ../kanban.gridColumns}}{{../kanban.gridColumns}}{{else}}4{{/if}}"
            >
              {{#each items}}
                {{> kanban-card basePath=../../basePath resource=../../resource kanban=../../kanban}}
              {{/each}}
            </div>
          {{else}}
            <p class="px-2 py-8 text-center text-sm text-body-subtle loom-card rounded-xl">No cards</p>
          {{/if}}
        </section>
      {{/each}}
    </div>
  {{else}}
    {{#each columns}}
      {{#if @first}}
        {{#if items.length}}
          <div
            class="loom-kanban-grid"
            style="--loom-kanban-cols: {{#if ../kanban.gridColumns}}{{../kanban.gridColumns}}{{else}}4{{/if}}"
          >
            {{#each items}}
              {{> kanban-card basePath=../../basePath resource=../../resource kanban=../../kanban}}
            {{/each}}
          </div>
        {{else}}
          <p class="px-2 py-12 text-center text-sm text-body-subtle loom-card rounded-xl">No cards</p>
        {{/if}}
      {{/if}}
    {{/each}}
  {{/if}}

  {{> pagination}}
</section>
