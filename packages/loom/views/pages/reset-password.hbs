<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{pageTitle}} · {{panelTitle}}</title>
  {{#if branding.fontUrl}}
    <link rel="stylesheet" href="{{branding.fontUrl}}" />
  {{/if}}
  <link rel="stylesheet" href="{{basePath}}/assets/admin.css" />
  <link rel="stylesheet" href="{{basePath}}/assets/branding.css" />
  {{#if csrfToken}}
    <meta name="csrf-token" content="{{csrfToken}}" />
  {{/if}}
  <script>
    (function () {
      const stored = localStorage.getItem('loom-theme');
      if (stored === 'dark' || (!stored && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark');
      }
    })();
  </script>
</head>
<body class="min-h-screen bg-loom-shell text-body antialiased flex items-center justify-center p-4">
  <div class="w-full max-w-md">
    <div class="text-center mb-8">
      <p class="text-2xl font-semibold text-heading tracking-tight">{{panelTitle}}</p>
      <p class="mt-2 text-sm text-body-subtle">Choose a new password</p>
    </div>

    {{#if flash}}
      <div class="mb-4 rounded-lg px-3 py-2 text-sm {{#if (eq flash.type 'error')}}bg-danger-soft text-fg-danger{{else}}bg-success-soft text-success-strong{{/if}}">
        {{flash.message}}
      </div>
    {{/if}}

    {{#if tokenValid}}
      <form method="post" action="{{basePath}}/reset-password" class="loom-card rounded-xl p-6 space-y-4 shadow-sm">
        {{> csrf}}
        <input type="hidden" name="token" value="{{token}}" />
        <div class="space-y-1.5">
          <label for="password" class="block text-sm font-medium text-heading">New password</label>
          <input
            id="password"
            type="password"
            name="password"
            required
            minlength="8"
            autofocus
            autocomplete="new-password"
            class="loom-input"
            placeholder="••••••••"
          />
        </div>
        <div class="space-y-1.5">
          <label for="passwordConfirm" class="block text-sm font-medium text-heading">Confirm password</label>
          <input
            id="passwordConfirm"
            type="password"
            name="passwordConfirm"
            required
            minlength="8"
            autocomplete="new-password"
            class="loom-input"
            placeholder="••••••••"
          />
        </div>
        <button
          type="submit"
          class="w-full inline-flex items-center justify-center gap-1.5 px-3 py-2.5 text-sm font-medium text-white rounded-md bg-fg-brand hover:opacity-90 transition-opacity"
        >
          Update password
        </button>
      </form>
    {{else}}
      <div class="loom-card rounded-xl p-6 space-y-4 shadow-sm text-center">
        <p class="text-sm text-body">This reset link is invalid or has expired.</p>
        <a href="{{basePath}}/forgot-password" class="text-sm text-fg-brand hover:underline">Request a new link</a>
      </div>
    {{/if}}
  </div>
</body>
</html>
