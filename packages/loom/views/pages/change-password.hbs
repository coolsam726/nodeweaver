<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{pageTitle}} · {{panelTitle}}</title>
  {{#if branding.fontUrl}}
    <link rel="stylesheet" href="{{branding.fontUrl}}" />
  {{/if}}
  <link rel="stylesheet" href="{{basePath}}/assets/admin.css" />
  <link rel="stylesheet" href="{{basePath}}/assets/branding.css" />
  {{#if csrfToken}}
    <meta name="csrf-token" content="{{csrfToken}}" />
  {{/if}}
  <script>
    (function () {
      const stored = localStorage.getItem('loom-theme');
      if (stored === 'dark' || (!stored && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark');
      }
    })();
  </script>
</head>
<body class="min-h-screen bg-loom-shell text-body antialiased flex items-center justify-center p-4">
  <div class="w-full max-w-md">
    <div class="text-center mb-8">
      <p class="text-2xl font-semibold text-heading tracking-tight">{{panelTitle}}</p>
      <p class="mt-2 text-sm text-body-subtle">Change your password</p>
    </div>

    {{#if flash}}
      <div class="mb-4 rounded-lg px-3 py-2 text-sm {{#if (eq flash.type 'error')}}bg-danger-soft text-fg-danger{{else}}bg-success-soft text-success-strong{{/if}}">
        {{flash.message}}
      </div>
    {{/if}}

    <form method="post" action="{{changePasswordPath}}" class="loom-card rounded-xl p-6 space-y-4 shadow-sm">
      {{> csrf}}
      <div class="space-y-1.5">
        <label for="currentPassword" class="block text-sm font-medium text-heading">Current password</label>
        <input
          id="currentPassword"
          type="password"
          name="currentPassword"
          required
          autofocus
          autocomplete="current-password"
          class="loom-input"
        />
      </div>
      <div class="space-y-1.5">
        <label for="password" class="block text-sm font-medium text-heading">New password</label>
        <input
          id="password"
          type="password"
          name="password"
          required
          minlength="8"
          autocomplete="new-password"
          class="loom-input"
        />
      </div>
      <div class="space-y-1.5">
        <label for="passwordConfirm" class="block text-sm font-medium text-heading">Confirm new password</label>
        <input
          id="passwordConfirm"
          type="password"
          name="passwordConfirm"
          required
          minlength="8"
          autocomplete="new-password"
          class="loom-input"
        />
      </div>
      <button
        type="submit"
        class="w-full inline-flex items-center justify-center gap-1.5 px-3 py-2.5 text-sm font-medium text-white rounded-md bg-fg-brand hover:opacity-90 transition-opacity"
      >
        Update password
      </button>
      <p class="text-center text-sm text-body-subtle space-x-3">
        <a href="{{accountPath}}" class="text-fg-brand hover:underline">Edit profile</a>
        <a href="{{basePath}}" class="text-fg-brand hover:underline">Back to admin</a>
      </p>
    </form>
  </div>
</body>
</html>
