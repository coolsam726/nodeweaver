<div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-3">
  {{#each menuRoots}}
    {{#unless (eq label 'Dashboard')}}
      <a
        href="{{href}}"
        class="group loom-card rounded-xl p-5 transition hover:bg-surface-row-hover"
      >
        <div class="mb-3 flex items-center gap-2.5">
          <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-surface-inset text-fg-brand">{{> icon name=icon class="w-4 h-4"}}</span>
          <h3 class="text-base font-semibold text-heading group-hover:text-fg-brand">{{label}}</h3>
        </div>
        <p class="text-sm text-body-subtle">Open {{label}}</p>
      </a>
    {{/unless}}
  {{/each}}
</div>
