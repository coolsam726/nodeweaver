{{#if embed}}
  <form
    id="velm-form"
    data-velm-embed-form
    method="post"
    action="{{#if (eq mode 'create')}}{{basePath}}/{{resource.slug}}{{else}}{{basePath}}/{{resource.slug}}/{{id}}{{/if}}"
    class="space-y-4"
  >
    {{#each resource.form.sections}}
      <fieldset class="velm-card rounded-xl p-4">
        <legend class="text-sm font-semibold text-heading mb-3 px-1">{{title}}</legend>
        {{#if description}}<p class="mb-3 -mt-1 text-sm text-body-subtle">{{description}}</p>{{/if}}
        <div class="grid gap-4 sm:grid-cols-{{columns}}">
          {{#each fields}}
            {{#unless hiddenOnForm}}
              {{#if @root.readonly}}
                {{#unless hiddenOnDetail}}
                  <div>
                    <label class="mb-1 block text-xs font-semibold uppercase tracking-wide text-body-subtle">{{label}}</label>
                    <p class="text-sm text-body">{{fieldValue @root.record this}}</p>
                  </div>
                {{/unless}}
              {{else}}
                {{#unless (and createOnly (eq @root.mode 'edit'))}}
                  {{> field-input}}
                {{/unless}}
              {{/if}}
            {{/unless}}
          {{/each}}
        </div>
      </fieldset>
    {{/each}}
    {{#unless readonly}}
      <div class="flex justify-end gap-2 pt-1">
        <button type="submit" class="inline-flex items-center gap-1.5 px-3 py-1.5 text-sm font-medium text-white rounded-md bg-fg-brand hover:opacity-90 transition">
          {{#if (eq mode 'create')}}Create{{else}}Save{{/if}}
        </button>
      </div>
    {{/unless}}
    {{#if readonly}}
      <div class="flex justify-end gap-2 pt-1">
        <a href="{{basePath}}/{{resource.slug}}/{{id}}/edit" class="inline-flex items-center gap-1.5 px-3 py-1.5 text-sm font-medium text-white rounded-md bg-fg-brand hover:opacity-90 transition">Edit</a>
      </div>
    {{/if}}
  </form>
{{else}}
<div class="mx-auto max-w-5xl space-y-6">
  <div class="velm-form-actions-bar flex items-center justify-between gap-3 sticky top-0 z-20 py-2 mb-2 bg-velm-shell/95 backdrop-blur-sm">
    <span class="inline-flex items-center gap-1.5 text-[10px] font-semibold uppercase tracking-wider px-2 py-0.5 rounded-full
      {{#if readonly}}bg-badge-neutral text-body-subtle
      {{else}}{{#if (eq mode 'edit')}}bg-warning-soft text-warning-strong
      {{else}}{{#if (eq mode 'create')}}bg-success-soft text-success-strong
      {{else}}bg-badge-neutral text-body-subtle{{/if}}{{/if}}{{/if}}">
      {{#if readonly}}detail{{else}}{{mode}}{{/if}}
    </span>
    <div class="flex items-center gap-2">
      {{#if readonly}}
        <a href="{{basePath}}/{{resource.slug}}/{{id}}/edit" class="inline-flex items-center gap-1.5 px-3 py-1.5 text-sm font-medium text-white rounded-md bg-fg-brand hover:opacity-90 transition">Edit</a>
      {{else}}
        <button type="submit" form="velm-form" class="inline-flex items-center gap-1.5 px-3 py-1.5 text-sm font-medium text-white rounded-md bg-fg-brand hover:opacity-90 transition">
          {{#if (eq mode 'create')}}Create{{else}}Save{{/if}}
        </button>
        <a href="{{basePath}}/{{resource.slug}}" data-velm-list-href="{{resource.slug}}" class="inline-flex items-center gap-1.5 px-3 py-1.5 text-sm font-medium border border-default text-body rounded-md hover:bg-surface-hover transition">Cancel</a>
      {{/if}}
    </div>
  </div>

  <form
    id="velm-form"
    method="post"
    action="{{#if (eq mode 'create')}}{{basePath}}/{{resource.slug}}{{else}}{{basePath}}/{{resource.slug}}/{{id}}{{/if}}"
    class="space-y-6"
  >
    {{#each resource.form.sections}}
      <fieldset class="velm-card rounded-xl p-6">
        <legend class="text-sm font-semibold text-heading mb-4 px-1">{{title}}</legend>
        {{#if description}}<p class="mb-4 -mt-2 text-sm text-body-subtle">{{description}}</p>{{/if}}
        <div class="grid gap-5 sm:grid-cols-{{columns}}">
          {{#each fields}}
            {{#unless hiddenOnForm}}
              {{#if @root.readonly}}
                {{#unless hiddenOnDetail}}
                  <div>
                    <label class="mb-1 block text-xs font-semibold uppercase tracking-wide text-body-subtle">{{label}}</label>
                    <p class="text-sm text-body">{{fieldValue @root.record this}}</p>
                  </div>
                {{/unless}}
              {{else}}
                {{#unless (and createOnly (eq @root.mode 'edit'))}}
                  {{> field-input}}
                {{/unless}}
              {{/if}}
            {{/unless}}
          {{/each}}
        </div>
      </fieldset>
    {{/each}}
  </form>
</div>
{{/if}}
