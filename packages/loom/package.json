{
  "name": "@nodeweaver/loom",
  "version": "0.1.6",
  "description": "Loom — declarative NestJS admin: resources, RBAC, tenancy, media, and JSON API (Handlebars + Tailwind + Alpine).",
  "keywords": [
    "nodeweaver",
    "nestjs",
    "admin",
    "admin-panel",
    "crud",
    "handlebars",
    "tailwindcss"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./nest": {
      "types": "./dist/nest/index.d.ts",
      "require": "./dist/nest/index.js",
      "import": "./dist/nest/index.js",
      "default": "./dist/nest/index.js"
    },
    "./base": {
      "types": "./dist/base/index.d.ts",
      "require": "./dist/base/index.js",
      "import": "./dist/base/index.js",
      "default": "./dist/base/index.js"
    }
  },
  "files": [
    "dist",
    "views",
    "assets"
  ],
  "scripts": {
    "build": "pnpm build:css && tsc && node scripts/copy-assets.mjs",
    "build:css": "rm -f ./assets/admin.css && tailwindcss -i ./assets/input.css -o ./assets/admin.css --minify",
    "dev:css": "tailwindcss -i ./assets/input.css -o ./assets/admin.css --watch",
    "test": "tsx --test test/**/*.test.ts",
    "prepublishOnly": "pnpm build"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "handlebars": "^4.7.8",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0"
  },
  "peerDependenciesMeta": {
    "typeorm": {
      "optional": true
    },
    "@nestjs/typeorm": {
      "optional": true
    },
    "@prisma/client": {
      "optional": true
    },
    "drizzle-orm": {
      "optional": true
    },
    "mongoose": {
      "optional": true
    },
    "@nestjs/mongoose": {
      "optional": true
    }
  },
  "devDependencies": {
    "@nestjs/common": "^11.1.3",
    "@nestjs/core": "^11.1.3",
    "@tailwindcss/cli": "^4.1.8",
    "@types/node": "^24.0.0",
    "alpinejs": "3.14.9",
    "drizzle-orm": "^0.44.2",
    "handlebars": "^4.7.8",
    "redoc": "2.5.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "swagger-ui-dist": "5.18.2",
    "tailwindcss": "^4.1.8",
    "tsx": "^4.20.3",
    "typeorm": "^0.3.25",
    "typescript": "^5.7.3"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/coolsam726/nodeweaver.git",
    "directory": "packages/loom"
  },
  "publishConfig": {
    "access": "public"
  }
}
