# Non-interactive installs (Docker / CI) — avoid TTY prompts when node_modules is reconciled
confirm-modules-purge=false
# Angular and other deps may need native build scripts on first install
dangerously-allow-all-builds=true
# Help Nuxt/autoprefixer/browserslist resolve peers inside Docker dev volumes
public-hoist-pattern[]=browserslist
public-hoist-pattern[]=node-releases
