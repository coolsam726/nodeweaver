{
  "name": "nodeweaver",
  "version": "0.1.3",
  "description": "Scaffold NestJS fullstack monorepos with Loom declarative admin",
  "type": "module",
  "bin": {
    "nodeweaver": "./dist/cli.js",
    "weaver": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "test": "tsx --test src/*.test.ts",
    "prepublishOnly": "pnpm build"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/coolsam726/nodeweaver.git",
    "directory": "packages/nodeweaver"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.5.1",
    "handlebars": "^4.7.8"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.20.3",
    "typescript": "^5.7.3"
  }
}
