<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{#if pageTitle}}{{pageTitle}} · {{/if}}{{brandName}}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;600;700&family=Poppins:wght@500;600;700;800&display=swap"
  />
  {{#if branding.fontUrl}}
    <link rel="stylesheet" href="{{branding.fontUrl}}" />
  {{/if}}
  <link rel="stylesheet" href="{{assetsPath}}/admin.css" />
  <link rel="stylesheet" href="{{assetsPath}}/branding.css" />
  <link rel="stylesheet" href="{{assetsPath}}/site.css" />
  {{#if csrfToken}}
    <meta name="csrf-token" content="{{csrfToken}}" />
  {{/if}}
  <script>
    (function () {
      const stored = localStorage.getItem('loom-theme');
      if (stored === 'dark' || (!stored && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark');
      }
    })();
  </script>
  <script defer src="{{assetsPath}}/loom-ui.js"></script>
  <script defer src="{{assetsPath}}/alpine.min.js"></script>
  <style>
    [x-cloak] { display: none !important; }
  </style>
</head>
<body class="site-body portal-shell antialiased" x-data="siteShell()">
  <header class="portal-nav">
    <a href="{{appPath}}" class="portal-nav__brand">{{brandName}}</a>
    <nav class="portal-nav__links" aria-label="Portal">
      <a href="{{appPath}}" class="site-nav__link is-active">Portal</a>
      <a href="{{homePath}}" class="site-nav__link">Home</a>
      <a href="{{adminPath}}" class="site-nav__link">Admin</a>
    </nav>
    <div class="site-nav__links">
      {{#if user}}
        <span class="site-nav__link" style="pointer-events:none;opacity:0.85">{{user.email}}</span>
        <a href="{{accountPath}}" class="site-nav__link">Profile</a>
        <a href="{{changePasswordPath}}" class="site-nav__link">Password</a>
      {{/if}}
      <button
        type="button"
        class="site-btn site-btn--quiet site-theme-toggle"
        @click="toggleTheme()"
        :aria-label="isDark ? 'Switch to light mode' : 'Switch to dark mode'"
        title="Toggle theme"
      >
        <svg x-show="!isDark" class="site-theme-toggle__icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/>
        </svg>
        <svg x-show="isDark" x-cloak class="site-theme-toggle__icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707M17.657 17.657l-.707-.707M6.343 6.343l-.707-.707M12 8a4 4 0 100 8 4 4 0 000-8z"/>
        </svg>
        <span x-text="isDark ? 'Light' : 'Dark'"></span>
      </button>
      <form method="post" action="{{logoutPath}}" class="inline">
        {{> csrf}}
        <button type="submit" class="site-btn site-btn--quiet">Sign out</button>
      </form>
    </div>
  </header>

  <main class="portal-main">
    {{{body}}}
  </main>

  <script>
    function siteShell() {
      return {
        isDark: document.documentElement.classList.contains('dark'),
        toggleTheme() {
          const root = document.documentElement;
          const next = root.classList.toggle('dark');
          this.isDark = next;
          localStorage.setItem('loom-theme', next ? 'dark' : 'light');
        },
      };
    }
  </script>
</body>
</html>
