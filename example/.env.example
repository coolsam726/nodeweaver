# Nest listen port (user-facing in dev and production)
PORT=4000

# Set to "production" for prod builds / start:prod
# NODE_ENV=production

# Nest dev proxy to frontend (set automatically in apps/api dev script)
# ENABLE_WEB_PROXY=true

# Frontend dev server URL (internal, used by Nest dev proxy)
WEB_DEV_URL=http://127.0.0.1:3000

# Bind frontend dev server to all interfaces (Docker sets WEB_DEV_HOST=0.0.0.0 for :3000 debug access)
# WEB_DEV_HOST=127.0.0.1

# Absolute API base for SSR fetches (frontend dev server does not route /api/* to Nest)
API_BASE_SERVER=http://127.0.0.1:4000/api

# Database (localhost — for pnpm dev on host)
DATABASE_URL="mongodb://localhost:27017/example"

# Redis (BullMQ — localhost for pnpm dev on host)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Docker Compose overrides DATABASE_URL / REDIS_HOST for the app service.

# ── Loom admin branding (@nestweaver/loom; VELM_BRAND_* still supported) ──
LOOM_BRAND_NAME=Example Admin
LOOM_BRAND_LOGO_URL=
LOOM_BRAND_LOGO_DARK_URL=
LOOM_BRAND_COPYRIGHT=© 2026 Example Inc. All rights reserved.
LOOM_BRAND_FONT_FAMILY=Inter, ui-sans-serif, system-ui, sans-serif
LOOM_BRAND_FONT_URL=https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap
LOOM_BRAND_PRIMARY_COLOR=#f1511b
LOOM_BRAND_ACCENT_COLOR=#286291