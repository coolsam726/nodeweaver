<nav class="flex-1 px-2 py-3 overflow-y-auto space-y-4" aria-label="Navigation">
  {{#each navGroups}}
    <div>
      <p class="px-3 mb-1 text-[11px] font-semibold uppercase tracking-wider text-body-subtle">{{name}}</p>
      <div class="space-y-0.5">
        {{#each items}}
          <a
            href="{{../../basePath}}/{{slug}}"
            class="nav-item flex items-center gap-2.5 px-3 py-2 rounded-md text-sm {{#if ../../resource}}{{#if (eq slug ../../resource.slug)}}nav-active{{/if}}{{/if}}"
            @click="sidebarOpen = false"
          >
            <span class="shrink-0 w-4 h-4">{{> icon name=(or icon 'squares-2x2') class="w-4 h-4"}}</span>
            <span class="truncate">{{label}}</span>
          </a>
        {{/each}}
      </div>
    </div>
  {{/each}}
</nav>
