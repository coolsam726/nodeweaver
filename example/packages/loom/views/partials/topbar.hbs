<header class="flex items-center gap-3 px-4 md:px-6 min-h-[60px] shrink-0 bg-velm-shell sticky top-0 z-30 overflow-visible">
  <button
    type="button"
    @click="sidebarOpen = true"
    aria-label="Open menu"
    class="md:hidden p-1.5 -ml-1.5 rounded-md text-body hover:bg-surface-hover"
  >
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
    </svg>
  </button>

  <div class="hidden md:flex flex-1 min-w-0 overflow-visible">
    <nav
      class="velm-app-menu flex-1 min-w-0 flex flex-wrap items-center gap-1 overflow-visible"
      x-data="{ openKey: '' }"
      @click.outside="openKey = ''"
      @keydown.escape.window="openKey = ''"
      aria-label="{{#if menuActiveRoot}}{{menuActiveRoot.label}} menu{{else}}App menu{{/if}}"
    >
      {{#if menuActiveRoot}}
        {{#unless menuSecondary.length}}
          <span class="shrink-0 text-sm font-semibold text-heading truncate max-w-[12rem]">{{menuActiveRoot.label}}</span>
        {{/unless}}
      {{/if}}

      {{#each menuSecondary}}
        {{#if children}}
          <div class="relative shrink-0">
            <button
              type="button"
              @click="openKey = openKey === 'sec-{{@index}}' ? '' : 'sec-{{@index}}'"
              class="flex items-center gap-1 px-2.5 py-1.5 rounded-md text-sm whitespace-nowrap {{#if active}}bg-surface-inset text-fg-brand font-medium{{else}}text-body hover:text-heading hover:bg-surface-hover{{/if}}"
              :aria-expanded="(openKey === 'sec-{{@index}}').toString()"
            >
              {{label}}
              <svg class="w-3 h-3 text-body-subtle transition-transform" :class="{ 'rotate-180': openKey === 'sec-{{@index}}' }" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5"/>
              </svg>
            </button>
            <div
              x-show="openKey === 'sec-{{@index}}'"
              x-cloak
              x-transition
              class="absolute left-0 top-full z-50 mt-1 min-w-[10rem] velm-card rounded-xl shadow-lg py-1"
            >
              {{#each children}}
                <a href="{{href}}" class="block px-3 py-1.5 text-sm whitespace-nowrap {{#if active}}text-fg-brand font-medium bg-surface-inset{{else}}text-body hover:bg-surface-hover hover:text-heading{{/if}}">{{label}}</a>
              {{/each}}
            </div>
          </div>
        {{else}}
          <a href="{{href}}" class="shrink-0 px-2.5 py-1.5 rounded-md text-sm whitespace-nowrap {{#if active}}bg-surface-inset text-fg-brand font-medium{{else}}text-body hover:text-heading hover:bg-surface-hover{{/if}}">{{label}}</a>
        {{/if}}
      {{/each}}
    </nav>
  </div>

  {{#if menuActiveRoot}}
    <p class="md:hidden flex-1 min-w-0 text-sm font-semibold text-heading truncate px-0.5">{{menuActiveRoot.label}}</p>
  {{else}}
    <div class="md:hidden flex-1 min-w-0" aria-hidden="true"></div>
  {{/if}}

  <div class="flex items-center gap-2 shrink-0">
    {{#if companies.length}}
      <div class="relative" x-data="{ open: false }" @click.outside="open = false">
        <button
          type="button"
          @click="open = !open"
          class="flex items-center gap-2 px-2.5 py-1.5 rounded-md text-sm text-body hover:text-heading hover:bg-surface-hover"
          aria-haspopup="true"
          :aria-expanded="open.toString()"
        >
          <svg class="w-4 h-4 text-body-subtle" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6h1.5m-1.5 3h1.5m-1.5 3H1.5M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21"/>
          </svg>
          <span class="hidden sm:inline truncate max-w-[160px]">{{#if currentCompanyName}}{{currentCompanyName}}{{else}}All companies{{/if}}</span>
          <svg class="w-3 h-3 text-body-subtle hidden sm:block" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5"/>
          </svg>
        </button>
        <div x-show="open" x-cloak x-transition class="absolute right-0 top-full mt-2 w-56 velm-card rounded-xl shadow-lg overflow-hidden z-50">
          <ul class="py-1 text-sm">
            <li>
              <button type="button" class="w-full text-left px-3 py-1.5 text-body hover:bg-surface-hover {{#unless currentCompanyId}}text-fg-brand font-medium{{/unless}}">All companies</button>
            </li>
            {{#each companies}}
              <li>
                <button type="button" class="w-full text-left px-3 py-1.5 text-body hover:bg-surface-hover {{#if (eq id ../currentCompanyId)}}text-fg-brand font-medium{{/if}}">{{name}}</button>
              </li>
            {{/each}}
          </ul>
        </div>
      </div>
    {{/if}}

    <button
      type="button"
      @click="toggleTheme()"
      aria-label="Toggle dark mode"
      class="p-1.5 rounded-md text-body hover:bg-surface-hover hover:text-heading"
    >
      <svg class="w-4 h-4 dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8">
        <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/>
      </svg>
      <svg class="w-4 h-4 hidden dark:block" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707M17.657 17.657l-.707-.707M6.343 6.343l-.707-.707M12 8a4 4 0 100 8 4 4 0 000-8z"/>
      </svg>
    </button>

    <div class="relative" x-data="{ open: false }" @click.outside="open = false">
      <button
        type="button"
        @click="open = !open"
        aria-haspopup="true"
        :aria-expanded="open.toString()"
        class="flex items-center gap-2 pl-1 pr-2 py-1 rounded-md hover:bg-surface-hover"
      >
        <span class="w-7 h-7 rounded-full bg-fg-brand text-white text-xs font-semibold flex items-center justify-center shrink-0">{{userInitial}}</span>
        <span class="hidden sm:inline text-sm font-medium text-body max-w-[120px] truncate">{{user.name}}</span>
        <svg class="w-3 h-3 text-body-subtle hidden sm:block" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5"/>
        </svg>
      </button>
      <div x-show="open" x-cloak x-transition class="absolute right-0 top-full mt-2 w-56 velm-card rounded-xl shadow-lg overflow-hidden z-50">
        <div class="px-4 py-3 border-b border-default">
          <p class="text-sm font-semibold text-heading truncate">{{user.name}}</p>
          {{#if user.email}}<p class="text-xs text-body-subtle">{{user.email}}</p>{{/if}}
        </div>
        <div class="py-1 text-sm">
          <a href="#" class="block px-4 py-1.5 text-body hover:bg-surface-hover hover:text-heading">My profile</a>
          <a href="{{basePath}}" class="block px-4 py-1.5 text-body hover:bg-surface-hover hover:text-heading">Admin</a>
          <a href="#" class="block px-4 py-1.5 text-body hover:bg-surface-hover hover:text-heading">Change password</a>
          <a href="/" class="block px-4 py-1.5 text-fg-danger hover:bg-danger-soft">Back to app</a>
        </div>
      </div>
    </div>
  </div>
</header>
