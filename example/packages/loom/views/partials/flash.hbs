{{#if flash}}
  <div
    class="mb-4 rounded-lg border px-4 py-3 text-sm {{#if (eq flash.type 'success')}}border-default bg-success-soft text-success-strong{{else}}border-default bg-danger-soft text-fg-danger{{/if}}"
    x-data="{ show: true }"
    x-show="show"
    x-transition
  >
    <div class="flex items-start justify-between gap-3">
      <p>{{flash.message}}</p>
      <button type="button" class="opacity-70 hover:opacity-100" @click="show = false">×</button>
    </div>
  </div>
{{/if}}
